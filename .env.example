# Example environment variables for local development

# Backend server port
PORT=4000

# Database URL for PostgreSQL (use your own credentials)
# Example: postgres://username:password@localhost:5432/newsverifier
DATABASE_URL=postgres://postgres:postgres@localhost:5432/newsverifier

# Optional OpenAI key if you want the server to use the OpenAI analyzer
# OPENAI_API_KEY=

# Frontend configuration
# Vite requires PORT and BASE_PATH for the app build/dev server
BASE_PATH=/
# PORT for frontend dev preview must be set in the frontend package environment or shell
# For local development, set PORT=5173 or another free port
