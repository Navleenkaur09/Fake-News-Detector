{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev:backend": "pnpm --filter @workspace/api-server dev",
    "dev:frontend": "pnpm --filter @workspace/fake-news-detector dev",
    "start:python-app": "python app.py",
    "train:model": "python train_model.py --train"
  },
  "private": true,
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.1"
  },
  "devDependencies": {
    "pnpm": "^11.10.0",
    "prettier": "^3.8.4",
    "typescript": "~5.9.3"
  }
}
